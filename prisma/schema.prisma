generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(uuid()) // Maps to Supabase Auth UUID
  email            String            @unique
  name             String?
  createdAt        DateTime          @default(now())
  workspaces       WorkspaceMember[]
  auditLogs        AuditLogEvent[]
  uploadedDocs     Document[]
}

model Workspace {
  id               String            @id @default(uuid())
  name             String
  ownerId          String
  createdAt        DateTime          @default(now())
  members          WorkspaceMember[]
  documents        Document[]
  scans            ScanRun[]
  auditLogs        AuditLogEvent[]
}

model WorkspaceMember {
  workspaceId      String
  userId           String
  role             String            // OWNER|ADMIN|MEMBER|VIEWER
  workspace        Workspace         @relation(fields: [workspaceId], references: [id])
  user             User              @relation(fields: [userId], references: [id])

  @@id([workspaceId, userId])
}

model Document {
  id                 String             @id @default(uuid())
  workspaceId        String
  filename           String
  mimeType           String
  storagePath        String
  size               Int
  uploadedBy         String
  uploadedAt         DateTime           @default(now())
  status             String             // UPLOADED|PROCESSED|FAILED
  extractedTextHash  String?
  workspace          Workspace          @relation(fields: [workspaceId], references: [id])
  user               User               @relation(fields: [uploadedBy], references: [id])
  versions           DocumentVersion[]
  metadata           DocumentMetadata?
}

model DocumentVersion {
  id               String      @id @default(uuid())
  documentId       String
  versionNumber    Int
  storagePath      String
  uploadedAt       DateTime    @default(now())
  uploadedBy       String
  document         Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model DocumentMetadata {
  documentId           String   @id
  docType              String   // Policy, Procedure, Evidence, Log, Contract, Register, Other
  confidence           Float
  tags                 Json?
  extractedTextPreview String?  @db.Text
  processedAt          DateTime @default(now())
  document             Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model Framework {
  id           String                 @id @default(uuid())
  code         String                 // ISO27001|GDPR
  name         String
  version      String
  description  String?
  requirements FrameworkRequirement[]
  scans        ScanRun[]
}

model FrameworkRequirement {
  id                String       @id @default(uuid())
  frameworkId       String
  code              String
  title             String
  description       String       @db.Text
  severity          String       // CRITICAL|MEDIUM|LOW
  requiredDocTypes  String[]
  keywords          String[]
  exampleEvidence   String       @db.Text
  guidance          String       @db.Text
  framework         Framework    @relation(fields: [frameworkId], references: [id])
  scanFindings      ScanFinding[]
}

model ScanRun {
  id               String        @id @default(uuid())
  workspaceId      String
  frameworkId      String
  startedAt        DateTime      @default(now())
  finishedAt       DateTime?
  status           String        // RUNNING|DONE|FAILED
  score            Float?
  ruleSetVersion   String
  createdBy        String
  workspace        Workspace     @relation(fields: [workspaceId], references: [id])
  framework        Framework     @relation(fields: [frameworkId], references: [id])
  findings         ScanFinding[]
}

model ScanFinding {
  id                   String               @id @default(uuid())
  scanRunId            String
  requirementId        String
  status               String               // PASS|FAIL|PARTIAL|NOT_APPLICABLE
  confidence           Float
  matchedDocumentIds   Json                 // Array of document IDs
  notes                String?              @db.Text
  recommendedActions   Json?                // Array of strings
  scanRun              ScanRun              @relation(fields: [scanRunId], references: [id])
  requirement          FrameworkRequirement @relation(fields: [requirementId], references: [id])
}

model AuditLogEvent {
  id           String      @id @default(uuid())
  workspaceId  String
  actorUserId  String
  action       String
  entityType   String
  entityId     String
  metadata     Json?
  createdAt    DateTime    @default(now())
  workspace    Workspace   @relation(fields: [workspaceId], references: [id])
  actor        User        @relation(fields: [actorUserId], references: [id])
}
